{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl * | sh)",
      "Bash(* > .env)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(ssh *)",
      "Bash(* > /dev/*)",
      "Read(.env*)",
      "Read(**/db/custom.db)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/pretool-guard.js\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-check.js\""
          }
        ]
      }
    ]
  }
}
